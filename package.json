{
  "name": "awesome-void",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.50.0",
    "simple-git-hooks": "^2.13.1",
    "vite-plus": "^0.1.21"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "oxfmt --write --no-error-on-unmatched-pattern"
  }
}
